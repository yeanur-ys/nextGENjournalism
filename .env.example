# Copy to .env and adjust if needed. Used by docker-compose and by
# apps/api when run outside Docker (go run ./cmd/api).
POSTGRES_DSN=postgres://nextgen:nextgen_dev@localhost:5432/nextgen?sslmode=disable
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nextgen_dev
JWT_SECRET=change-me-to-a-long-random-string-in-real-deployments
HTTP_PORT=8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DEBEZIUM_CONNECT_URL=http://localhost:8083
