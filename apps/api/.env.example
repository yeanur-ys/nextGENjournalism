# See root-level .env.example — this file exists so apps/api works if you
# `cd apps/api && go run ./cmd/api` in isolation during backend-only development.
POSTGRES_DSN=postgres://nextgen:nextgen_dev@localhost:5432/nextgen?sslmode=disable
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nextgen_dev
JWT_SECRET=change-me-to-a-long-random-string-in-real-deployments
HTTP_PORT=8080
